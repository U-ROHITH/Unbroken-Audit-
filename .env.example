# Client-exposed (safe — anon/publishable key only)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# NEVER expose the service-role / secret key to the browser.
# It is only used by server-side scripts / migrations, never imported in src/.
# SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx
